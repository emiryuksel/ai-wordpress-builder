# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Session imzalama (production'da güçlü rastgele bir değer kullanın)
SESSION_SECRET=

# Production (Coolify): ana uygulama URL'si — siteler /{slug} altında yayınlanır
# APP_URL=https://wp.withsolver.com

# Internal: container'dan WP container'larına erişim (port tabanlı, public URL değil)
# WORDPRESS_REACHABILITY_HOST=host.docker.internal

# Admin hesabı (ilk çalıştırmada otomatik oluşturulur, site limiti yok)
ADMIN_EMAIL=admin@solver.com
ADMIN_PASSWORD=degistirin-guclu-sifre
ADMIN_NAME=Admin

# Optional: image generation model (default: gemini-2.5-flash-image)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
